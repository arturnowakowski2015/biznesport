{
    "name": "biznesport-backend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "start": "ts-node src/server.ts",
        "migrate": "sequelize-cli db:migrate",
        "seed": "sequelize-cli db:seed:all",
        "start:docker": "sh ./scripts/start-docker.sh"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "dotenv": "^16.4.5",
        "express": "^4.22.1",
        "mysql2": "^3.22.2",
        "pg": "^8.12.0",
        "pg-hstore": "^2.3.4",
        "sequelize": "^6.37.8"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.25",
        "@types/node": "^22.19.17",
        "nodemon": "^3.1.4",
        "sequelize-cli": "^6.6.2",
        "ts-node": "^10.9.2",
        "tsx": "^4.19.1",
        "typescript": "^5.9.3"
    }
}